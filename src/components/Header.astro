---
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<div class="bar">
		<a href="/" class="mark" aria-label="NIAID BRC AI Codeathon home">
			<span class="mark-meta">NIAID · BRC</span>
			<span class="mark-title">AI Codeathon <em>2.0</em></span>
		</a>

		<nav class="internal-links">
			<HeaderLink href="/">Overview</HeaderLink>
			<HeaderLink href="/schedule">Schedule</HeaderLink>
			<HeaderLink href="/projects">Past Projects</HeaderLink>
			<HeaderLink href="/report">Report</HeaderLink>
		</nav>

		<div class="social-links">
			<a
				href="https://github.com/NIAID-BRC-Codeathons"
				target="_blank"
				rel="noopener"
			>
				<span class="sr-only">Codeathon GitHub Organization</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</div>
	<div class="rule"></div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(245, 240, 229, 0.92);
		backdrop-filter: saturate(120%) blur(10px);
		-webkit-backdrop-filter: saturate(120%) blur(10px);
	}
	.bar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1.5em;
		max-width: 1280px;
		margin: 0 auto;
		padding: 1em 1.25em;
	}
	.mark {
		text-decoration: none;
		color: var(--ink);
		display: flex;
		flex-direction: column;
		line-height: 1.05;
	}
	.mark-meta {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--mute);
	}
	.mark-title {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin-top: 2px;
	}
	.mark-title em {
		font-style: normal;
		color: var(--rust);
		font-weight: 500;
		margin-left: 0.15em;
	}
	nav.internal-links {
		display: flex;
		justify-content: center;
		gap: 2em;
	}
	nav.internal-links :global(a) {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--ink-soft);
		text-decoration: none;
		padding: 0.4em 0;
		border-bottom: 1px solid transparent;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	nav.internal-links :global(a:hover) {
		color: var(--rust);
		text-decoration: none;
	}
	nav.internal-links :global(a.active) {
		color: var(--ink);
		border-bottom-color: var(--rust);
		font-weight: 500;
	}
	.social-links {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 1em;
	}
	.social-links a {
		display: inline-flex;
		color: var(--ink-soft);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--rust);
	}
	.rule {
		height: 1px;
		background: var(--rule);
	}
	@media (max-width: 820px) {
		.bar {
			grid-template-columns: 1fr auto;
			gap: 0.75em;
		}
		.social-links {
			grid-column: 2;
			grid-row: 1;
		}
		nav.internal-links {
			grid-column: 1 / -1;
			grid-row: 2;
			justify-content: flex-start;
			gap: 1.25em;
			flex-wrap: wrap;
		}
		nav.internal-links :global(a) {
			font-size: 0.72rem;
		}
	}
</style>
