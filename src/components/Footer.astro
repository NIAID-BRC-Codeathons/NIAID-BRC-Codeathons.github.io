---
import {
	APPLICATION_DEADLINE,
	EVENT_DATE,
	EVENT_LOCATION,
	EVENT_YEAR,
} from "../consts";
import Mark from "./Mark.astro";
---

<footer>
	<div class="inner">
		<div class="col">
			<div class="label-row">
				<Mark size={10} color="#f3a76b" variant="node" />
				<span class="label">Event</span>
			</div>
			<p class="value">
				NIAID BRC AI Codeathon <em>2.0</em>
			</p>
			<p class="meta">{EVENT_DATE}</p>
			<p class="meta">{EVENT_LOCATION}</p>
		</div>

		<div class="col">
			<span class="label">Apply</span>
			<p class="meta">
				Deadline <span class="emph">{APPLICATION_DEADLINE}</span>
			</p>
			<p class="meta">Application form coming soon.</p>
		</div>

		<div class="col col-end">
			<span class="label">Find Us</span>
			<a
				href="https://github.com/NIAID-BRC-Codeathons"
				target="_blank"
				rel="noopener"
				class="link"
			>
				github.com/NIAID-BRC-Codeathons ↗
			</a>
			<p class="meta tiny">
				© {EVENT_YEAR} NIAID Bioinformatics Resource Centers
			</p>
		</div>
	</div>

	<div class="big-mark" aria-hidden="true">CODEATHON&nbsp;2.0</div>
</footer>

<style>
	footer {
		margin-top: 6em;
		padding: 4em 1.25em 2em;
		background: var(--ink);
		color: rgba(245, 240, 229, 0.78);
		position: relative;
		overflow: hidden;
	}
	.inner {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 3em;
		max-width: 1280px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}
	.col {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.col-end {
		align-items: flex-start;
	}
	.label-row {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin-bottom: 0.5em;
	}
	.label {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(245, 240, 229, 0.65);
		margin-bottom: 0.5em;
	}
	.label-row .label {
		margin-bottom: 0;
	}
	.value {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 500;
		color: var(--paper);
		margin: 0;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}
	.value em {
		font-style: normal;
		color: #f3a76b;
		font-weight: 500;
	}
	.meta {
		font-size: 0.9rem;
		margin: 0;
		color: rgba(245, 240, 229, 0.7);
	}
	.tiny {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		margin-top: 1em;
		color: rgba(245, 240, 229, 0.6);
	}
	.emph {
		color: var(--paper);
		font-weight: 600;
	}
	.link {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--paper);
		text-decoration: none;
		border-bottom: 1px solid rgba(245, 240, 229, 0.3);
		padding-bottom: 2px;
		transition: border-color 0.2s ease;
	}
	.link:hover {
		border-bottom-color: #f3a76b;
		color: #f3a76b;
	}
	.big-mark {
		position: absolute;
		bottom: -2.5rem;
		left: 50%;
		transform: translateX(-50%);
		font-family: var(--font-display);
		font-weight: 200;
		font-size: clamp(8rem, 22vw, 18rem);
		letter-spacing: -0.05em;
		color: rgba(245, 240, 229, 0.04);
		pointer-events: none;
		white-space: nowrap;
		z-index: 0;
		line-height: 1;
	}
	@media (max-width: 820px) {
		.inner {
			grid-template-columns: 1fr;
			gap: 2em;
		}
		.big-mark {
			font-size: clamp(5rem, 30vw, 9rem);
			bottom: -1rem;
		}
	}
</style>
