---
interface Props {
	size?: number;
	color?: string;
	variant?: "solid" | "node" | "pair";
	class?: string;
}

const {
	size = 14,
	color = "currentColor",
	variant = "node",
	class: className,
} = Astro.props;
---

{
	variant === "node" && (
		<svg
			class={className}
			width={size}
			height={size}
			viewBox="0 0 14 14"
			fill="none"
			aria-hidden="true"
		>
			<circle cx="7" cy="7" r="6" stroke={color} stroke-width="1" />
			<circle cx="7" cy="7" r="1.8" fill={color} />
		</svg>
	)
}
{
	variant === "solid" && (
		<svg
			class={className}
			width={size}
			height={size}
			viewBox="0 0 14 14"
			fill="none"
			aria-hidden="true"
		>
			<circle cx="7" cy="7" r="3.5" fill={color} />
		</svg>
	)
}
{
	variant === "pair" && (
		<svg
			class={className}
			width={size * 2.4}
			height={size}
			viewBox="0 0 34 14"
			fill="none"
			aria-hidden="true"
		>
			<circle cx="6" cy="7" r="2.5" fill={color} />
			<line x1="9" y1="7" x2="24" y2="7" stroke={color} stroke-width="1" />
			<circle cx="27" cy="7" r="5.5" stroke={color} stroke-width="1" />
			<circle cx="27" cy="7" r="1.6" fill={color} />
		</svg>
	)
}
