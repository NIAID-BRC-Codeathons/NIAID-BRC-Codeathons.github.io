---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Mark from "../components/Mark.astro";
import {
	APPLICATION_DEADLINE,
	EVENT_DATE,
	EVENT_LOCATION,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2.5em);
				padding-top: 1em;
			}

			/* ---------- Hero ---------- */
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
				gap: 3em;
				padding: 4em 0 5em;
				position: relative;
			}
			.hero-eyebrow {
				grid-column: 1 / -1;
				display: flex;
				gap: 1em;
				align-items: center;
				margin-bottom: 1.5em;
				color: var(--rust);
			}
			.hero-eyebrow .sep {
				flex: 1;
				height: 1px;
				background: var(--rust);
				opacity: 0.45;
			}
			.hero-title {
				margin: 0;
				font-size: clamp(3.25rem, 9vw, 7.5rem);
				font-weight: 100;
				letter-spacing: -0.055em;
				line-height: 0.9;
				color: var(--ink);
			}
			.hero-title .line {
				display: block;
				white-space: nowrap;
			}
			.hero-title .big-num {
				font-family: var(--font-display);
				font-weight: 200;
				color: var(--rust);
				letter-spacing: -0.05em;
			}
			.hero-subtitle {
				margin-top: 1.2em;
				font-family: var(--font-display);
				font-weight: 300;
				font-size: clamp(1.35rem, 2.2vw, 1.9rem);
				line-height: 1.3;
				color: var(--ink);
				letter-spacing: -0.02em;
				max-width: 26ch;
			}

			.hero-meta {
				border-left: 1px solid var(--rule);
				padding: 0.5em 0 0.5em 1.75em;
				display: flex;
				flex-direction: column;
				gap: 1.4em;
				align-self: end;
			}
			.meta-block .meta-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--mute);
				display: block;
				margin-bottom: 0.35em;
			}
			.meta-block .meta-value {
				font-family: var(--font-display);
				font-size: 1.25rem;
				color: var(--ink);
				line-height: 1.25;
				font-weight: 500;
				letter-spacing: -0.015em;
			}
			.meta-block .meta-sub {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--ink-soft);
				margin-top: 0.15em;
			}

			.hero-actions {
				grid-column: 1 / -1;
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				margin-top: 2.5em;
				align-items: center;
			}
			.hero-actions .status {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--mute);
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
			}
			.hero-actions .status::before {
				content: "";
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: var(--rust);
				box-shadow: 0 0 0 4px rgba(184, 69, 31, 0.18);
				animation: pulse 2.6s ease-in-out infinite;
			}
			@keyframes pulse {
				0%,
				100% {
					box-shadow: 0 0 0 4px rgba(184, 69, 31, 0.18);
				}
				50% {
					box-shadow: 0 0 0 8px rgba(184, 69, 31, 0);
				}
			}

			/* ---------- Section divider ---------- */
			.section-mark {
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2.5em 0;
				gap: 1.25em;
				color: var(--rust);
				opacity: 0.55;
			}
			.section-mark .line {
				flex: 1;
				max-width: 8rem;
				height: 1px;
				background: var(--rule);
			}

			/* ---------- Intro / lede ---------- */
			.intro {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
				gap: 3em;
				padding: 4em 0;
				border-top: 1px solid var(--rule);
			}
			.intro-label {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--mute);
			}
			.intro-body {
				font-size: 1.05rem;
				line-height: 1.65;
				color: var(--ink-soft);
				max-width: 60ch;
			}
			.intro-body p:first-child::first-letter {
				font-family: var(--font-display);
				font-weight: 200;
				font-size: 4em;
				float: left;
				line-height: 0.9;
				padding: 0.08em 0.1em 0 0;
				color: var(--ink);
				letter-spacing: -0.05em;
			}

			/* ---------- Focus areas ---------- */
			.focus {
				padding: 2em 0 3em;
			}
			.focus-head {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
				gap: 3em;
				margin-bottom: 3em;
			}
			.focus-head h2 {
				margin: 0;
				font-size: clamp(2.2rem, 4.5vw, 3.75rem);
				font-weight: 300;
				letter-spacing: -0.035em;
				line-height: 1.05;
			}
			.focus-head h2 em {
				font-style: normal;
				color: var(--rust);
				font-weight: 300;
			}
			.focus-tag {
				position: relative;
				padding-left: 1.5em;
			}
			.focus-tag::before {
				content: "";
				position: absolute;
				left: 0;
				top: 0.45em;
				width: 0.75em;
				height: 1px;
				background: var(--teal);
			}
			.focus-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
			}
			.focus-item {
				display: grid;
				grid-template-columns: 8rem minmax(0, 1.4fr) minmax(0, 1.6fr);
				gap: 2.5em;
				padding: 2.5em 0;
				border-top: 1px solid var(--rule);
				align-items: start;
			}
			.focus-item:last-child {
				border-bottom: 1px solid var(--rule);
			}
			.focus-num {
				font-family: var(--font-display);
				font-weight: 200;
				font-size: clamp(3rem, 6vw, 5.5rem);
				line-height: 0.9;
				color: var(--rust);
				letter-spacing: -0.06em;
			}
			.focus-title {
				font-family: var(--font-display);
				font-size: clamp(1.3rem, 2.1vw, 1.75rem);
				font-weight: 500;
				line-height: 1.25;
				color: var(--ink);
				margin: 0 0 0.6em 0;
				letter-spacing: -0.02em;
			}
			.focus-tag {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 0.75em;
			}
			.focus-desc {
				color: var(--ink-soft);
				font-size: 0.98rem;
				line-height: 1.6;
				margin: 0;
			}

			/* ---------- Goals + Who ---------- */
			.two-col {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
				gap: 4em;
				padding: 2em 0 5em;
			}
			.two-col h3 {
				font-size: 1.85rem;
				font-weight: 500;
				margin: 0 0 1em 0;
				letter-spacing: -0.015em;
			}
			.listed {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.listed li {
				padding: 1em 0;
				border-top: 1px solid var(--rule);
				display: grid;
				grid-template-columns: 2rem 1fr;
				gap: 1em;
				color: var(--ink-soft);
				font-size: 0.98rem;
				line-height: 1.5;
			}
			.listed li:last-child {
				border-bottom: 1px solid var(--rule);
			}
			.listed li::before {
				content: counter(item, decimal-leading-zero);
				counter-increment: item;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				color: var(--rust);
				letter-spacing: 0.1em;
				padding-top: 0.3em;
			}
			.listed {
				counter-reset: item;
			}

			/* ---------- Apply CTA ---------- */
			.apply {
				display: grid;
				grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
				gap: 3em;
				padding: 5em 2.5em;
				margin-top: 4em;
				background: var(--ink);
				color: var(--paper);
				position: relative;
				overflow: hidden;
			}
			.apply::before {
				content: "";
				position: absolute;
				inset: 0;
				background-image: radial-gradient(
						circle at 20% 30%,
						rgba(184, 69, 31, 0.18),
						transparent 60%
					),
					radial-gradient(
						circle at 80% 80%,
						rgba(45, 88, 98, 0.22),
						transparent 60%
					);
				pointer-events: none;
			}
			.apply > * {
				position: relative;
				z-index: 1;
			}
			.apply .eyebrow-light {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: rgba(245, 240, 229, 0.65);
			}
			.apply h2 {
				color: var(--paper);
				margin: 0.5em 0 0.6em 0;
				font-size: clamp(2rem, 4vw, 3.25rem);
				font-weight: 300;
				letter-spacing: -0.035em;
				line-height: 1.1;
			}
			.apply h2 em {
				font-style: normal;
				color: #f3a76b;
				font-weight: 300;
			}
			.apply p {
				color: rgba(245, 240, 229, 0.8);
				max-width: 48ch;
			}
			.apply .deadline-card {
				border-left: 1px solid rgba(245, 240, 229, 0.25);
				padding-left: 2em;
				align-self: center;
			}
			.apply .deadline-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: rgba(245, 240, 229, 0.55);
				display: block;
				margin-bottom: 0.4em;
			}
			.apply .deadline-date {
				font-family: var(--font-display);
				font-weight: 300;
				font-size: clamp(1.85rem, 3.5vw, 2.5rem);
				line-height: 1.1;
				letter-spacing: -0.025em;
				color: #f3a76b;
				margin-bottom: 0.5em;
			}
			.apply .deadline-note {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				color: rgba(245, 240, 229, 0.6);
				margin: 0;
			}
			.apply .btn-light {
				display: inline-flex;
				gap: 0.5em;
				align-items: center;
				margin-top: 1.5em;
				padding: 1em 1.6em;
				background: var(--paper);
				color: var(--ink);
				font-family: var(--font-mono);
				font-size: 0.78rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				font-weight: 500;
				text-decoration: none;
				transition:
					background 0.2s ease,
					transform 0.2s ease;
			}
			.apply .btn-light:hover {
				background: #f3a76b;
				transform: translateY(-1px);
				color: var(--ink);
				text-decoration: none;
			}

			@media (max-width: 820px) {
				.hero,
				.intro,
				.focus-head,
				.two-col,
				.apply {
					grid-template-columns: 1fr;
				}
				.hero-meta {
					border-left: none;
					border-top: 1px solid var(--rule);
					padding: 1.5em 0 0;
				}
				.focus-item {
					grid-template-columns: 4rem 1fr;
					gap: 1.25em;
				}
				.focus-item > .focus-desc {
					grid-column: 1 / -1;
				}
				.apply .deadline-card {
					border-left: none;
					border-top: 1px solid rgba(245, 240, 229, 0.25);
					padding: 1.5em 0 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-eyebrow reveal reveal-1">
					<Mark size={12} color="var(--rust)" variant="node" />
					<span class="eyebrow">Sept 16 — 18, 2026 · Argonne National Lab</span>
					<span class="sep"></span>
				</div>

				<div>
					<h1 class="hero-title reveal reveal-2">
						<span class="line">AI Codeathon</span>
						<span class="line big-num">2.0</span>
					</h1>
					<p class="hero-subtitle reveal reveal-3">
						Accelerating FAIR data and tools for infectious disease research.
					</p>
				</div>

				<div class="hero-meta reveal reveal-4">
					<div class="meta-block">
						<span class="meta-label">Dates</span>
						<div class="meta-value">{EVENT_DATE}</div>
						<div class="meta-sub">3 days · in person · Wed → Fri</div>
					</div>
					<div class="meta-block">
						<span class="meta-label">Venue</span>
						<div class="meta-value">{EVENT_LOCATION}</div>
						<div class="meta-sub">Bldg 240 · Room 1416</div>
					</div>
					<div class="meta-block">
						<span class="meta-label">Applications close</span>
						<div class="meta-value">{APPLICATION_DEADLINE}</div>
						<div class="meta-sub">Form coming soon</div>
					</div>
				</div>

				<div class="hero-actions reveal reveal-5">
					<a href="/schedule/" class="btn-primary">View Schedule →</a>
					<a href="/projects/" class="btn-secondary">2025 Project Archive</a>
					<span class="status">Applications open soon</span>
				</div>
			</section>

			<section class="intro">
				<div>
					<span class="intro-label">About the event</span>
				</div>
				<div class="intro-body">
					<p>
						The NIAID Bioinformatics Resource Centers (BRCs) invite researchers,
						data scientists, developers, bioinformaticians, and students to a
						three-day in-person codeathon focused on advancing infectious
						disease research through AI, large language models, and agentic
						frameworks.
					</p>
					<p>
						Building on the success of the previous codeathon, participants
						will collaborate in small teams to develop prototype tools and
						workflows that improve the
						<strong
							>Findability, Accessibility, Interoperability, and Reusability</strong
						>
						of BRC data, resources, and analysis tools.
					</p>
				</div>
			</section>

			<div class="section-mark" aria-hidden="true">
				<span class="line"></span>
				<Mark size={14} color="var(--rust)" variant="pair" />
				<span class="line"></span>
			</div>

			<section class="focus">
				<div class="focus-head">
					<span class="eyebrow">Focus Areas, 2026</span>
					<h2>
						Two directions.<br /><em>One common goal.</em>
					</h2>
				</div>

				<ol class="focus-list">
					<li class="focus-item">
						<div class="focus-num">01</div>
						<div>
							<div class="focus-tag">RAG · LLM</div>
							<h3 class="focus-title">
								Automated knowledge extraction &amp; curation from literature
							</h3>
						</div>
						<p class="focus-desc">
							AI-driven systems that automatically extract, structure, and
							integrate biological and epidemiological knowledge from the
							scientific literature using Retrieval-Augmented Generation and
							large language models — linked back to BRC schemas with
							provenance.
						</p>
					</li>

					<li class="focus-item">
						<div class="focus-num">02</div>
						<div>
							<div class="focus-tag">MCP · Agentic AI</div>
							<h3 class="focus-title">
								Bioinformatics workflow automation
							</h3>
						</div>
						<p class="focus-desc">
							Agent-based systems that translate research questions into
							executable bioinformatics workflows by leveraging Model Context
							Protocol (MCP)-enabled tools and services — adaptive, multi-step,
							and reproducible.
						</p>
					</li>
				</ol>
			</section>

			<div class="section-mark" aria-hidden="true">
				<span class="line"></span>
				<Mark size={14} color="var(--teal)" variant="node" />
				<span class="line"></span>
			</div>

			<section class="two-col">
				<div>
					<span class="eyebrow eyebrow--teal">Goals</span>
					<h3>What we hope to ship.</h3>
					<ul class="listed">
						<li>
							Apply AI and LLMs to enable scalable knowledge extraction from
							scientific literature
						</li>
						<li>
							Develop intelligent systems for automated workflow design &amp;
							execution
						</li>
						<li>
							Enhance interoperability and reuse of BRC data, tools, and
							services
						</li>
						<li>
							Foster collaboration across infectious disease, AI, and
							bioinformatics communities
						</li>
						<li>
							Deliver openly available prototypes that seed long-term community
							solutions
						</li>
					</ul>
				</div>

				<div>
					<span class="eyebrow eyebrow--teal">Who should apply</span>
					<h3>Bring your discipline.</h3>
					<ul class="listed">
						<li>Infectious disease researchers and domain experts</li>
						<li>Data scientists and AI/ML researchers</li>
						<li>Bioinformaticians and computational biologists</li>
						<li>Software developers and research engineers</li>
						<li>Students, postdocs, and trainees</li>
					</ul>
				</div>
			</section>

			<section class="apply">
				<div>
					<span class="eyebrow-light">Apply</span>
					<h2>
						Three days at <em>Argonne</em>.<br />Free to attend.
					</h2>
					<p>
						Participation is free, but space is limited. Application form and
						additional details on registration, project themes, and logistics
						will be announced soon.
					</p>
					<a href="/schedule/" class="btn-light">View Full Schedule →</a>
				</div>
				<div class="deadline-card">
					<span class="deadline-label">Application Deadline</span>
					<div class="deadline-date">{APPLICATION_DEADLINE}</div>
					<p class="deadline-note">
						Notifications shortly after. Confirmed teams begin bi-weekly
						preparatory calls.
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
