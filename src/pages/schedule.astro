---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Mark from "../components/Mark.astro";
import { EVENT_DATE, EVENT_LOCATION, SITE_TITLE } from "../consts";

type Item = { time: string; title: string; tag?: string; muted?: boolean };
type Day = {
	num: string;
	weekday: string;
	date: string;
	theme: string;
	items: Item[];
};

const days: Day[] = [
	{
		num: "16",
		weekday: "Wed",
		date: "September 16, 2026",
		theme: "Kickoff · Charge · Teams",
		items: [
			{ time: "08:30", title: "Check-in, Meet & Greet", tag: "Arrival" },
			{ time: "09:00", title: "Welcome and Introductions" },
			{
				time: "09:15",
				title: "AI Update: The Future of Scientific Discovery",
				tag: "Keynote",
			},
			{ time: "10:00", title: "Codeathon Overview and Charge" },
			{ time: "10:30", title: "Breakout Sessions", tag: "Build" },
			{ time: "12:00", title: "Lunch Break", muted: true },
			{ time: "13:00", title: "Breakout Sessions", tag: "Build" },
			{ time: "15:00", title: "Aurora Reveal Tour", tag: "Tour" },
			{ time: "15:30", title: "Icebreaker Bingo" },
			{ time: "16:00", title: "Team Reports", tag: "Reports" },
			{ time: "17:00", title: "Adjourn", muted: true },
			{ time: "17:30", title: "Group Dinner (optional)", muted: true },
		],
	},
	{
		num: "17",
		weekday: "Thu",
		date: "September 17, 2026",
		theme: "Prototyping · Iteration",
		items: [
			{ time: "08:30", title: "Check-in", tag: "Arrival" },
			{ time: "09:00", title: "Recap from Day 1, Day 2 Charge" },
			{ time: "09:30", title: "Breakout Sessions", tag: "Build" },
			{ time: "12:00", title: "Lunch Break", muted: true },
			{ time: "13:00", title: "Rapid Prototyping Lab Tour", tag: "Tour" },
			{ time: "13:30", title: "Breakout Sessions", tag: "Build" },
			{ time: "16:00", title: "Team Reports", tag: "Reports" },
			{ time: "17:00", title: "Adjourn", muted: true },
		],
	},
	{
		num: "18",
		weekday: "Fri",
		date: "September 18, 2026",
		theme: "Final Push · Presentations",
		items: [
			{ time: "08:30", title: "Check-in", tag: "Arrival" },
			{ time: "09:00", title: "Recap from Day 2, Day 3 Charge" },
			{ time: "09:30", title: "Breakout Sessions", tag: "Build" },
			{ time: "12:00", title: "Lunch Break", muted: true },
			{ time: "13:00", title: "Project Presentations", tag: "Finale" },
			{ time: "15:00", title: "Discussion and Closeout" },
			{ time: "15:30", title: "Codeathon Concludes", muted: true },
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Schedule | ${SITE_TITLE}`}
			description={`NIAID BRC AI Codeathon 2.0 Schedule — ${EVENT_DATE} at ${EVENT_LOCATION}`}
		/>
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2.5em);
				margin: auto;
				padding: 2em 1.25em 4em;
			}

			.page-head {
				display: grid;
				grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
				gap: 3em;
				padding: 3em 0 4em;
				border-bottom: 1px solid var(--rule);
			}
			.page-head .head-eyebrow {
				display: flex;
				align-items: center;
				gap: 0.7em;
				color: var(--rust);
			}
			.page-head h1 {
				margin: 0.4em 0 0 0;
				font-size: clamp(2.75rem, 7vw, 5.5rem);
				font-weight: 100;
				letter-spacing: -0.055em;
				line-height: 1;
			}
			.page-head h1 em {
				font-style: normal;
				color: var(--rust);
				font-weight: 100;
			}
			.venue-card {
				border-left: 1px solid var(--rule);
				padding: 0.25em 0 0.25em 1.75em;
				align-self: end;
				display: flex;
				flex-direction: column;
				gap: 1.25em;
			}
			.venue-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--mute);
				margin-bottom: 0.35em;
				display: block;
			}
			.venue-room {
				font-family: var(--font-display);
				font-size: 1.25rem;
				color: var(--ink);
				font-weight: 500;
				letter-spacing: -0.015em;
			}
			.venue-addr {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--ink-soft);
				line-height: 1.5;
			}

			.day {
				display: grid;
				grid-template-columns: 11rem minmax(0, 1fr);
				gap: 3em;
				padding: 4.5em 0;
				border-bottom: 1px solid var(--rule);
				align-items: start;
			}
			.day:last-of-type {
				border-bottom: none;
			}
			.day-rail {
				position: sticky;
				top: 7rem;
				display: flex;
				flex-direction: column;
				gap: 0.5em;
			}
			.day-num {
				font-family: var(--font-display);
				font-weight: 100;
				font-size: clamp(5rem, 11vw, 8rem);
				line-height: 0.85;
				color: var(--rust);
				letter-spacing: -0.06em;
				position: relative;
				display: inline-block;
			}
			.day-num::after {
				content: "";
				position: absolute;
				left: 0;
				bottom: 0.1em;
				width: 1.5em;
				height: 1px;
				background: var(--rust);
				opacity: 0.4;
			}
			.day-weekday {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--mute);
				margin-top: 0.4em;
			}
			.day-date {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--ink-soft);
			}
			.day-theme {
				font-family: var(--font-display);
				font-weight: 400;
				font-size: 1rem;
				color: var(--teal);
				margin-top: 0.5em;
				line-height: 1.35;
				letter-spacing: -0.01em;
			}

			.day-body {
				display: flex;
				flex-direction: column;
			}
			.row {
				display: grid;
				grid-template-columns: 5.5rem 1fr 6rem;
				gap: 1.5em;
				padding: 1.1em 0;
				border-top: 1px solid var(--rule);
				align-items: baseline;
				transition: background 0.2s ease;
			}
			.row:first-child {
				border-top: 1px solid var(--ink);
			}
			.row:last-child {
				border-bottom: 1px solid var(--rule);
			}
			.row:hover {
				background: rgba(184, 69, 31, 0.04);
			}
			.row--muted {
				color: var(--mute);
			}
			.row--muted .row-title {
				color: var(--mute);
				font-weight: 300;
			}
			.row-time {
				font-family: var(--font-mono);
				font-size: 0.95rem;
				color: var(--ink);
				font-weight: 500;
			}
			.row-title {
				font-family: var(--font-body);
				font-size: 1.05rem;
				color: var(--ink);
				font-weight: 500;
				letter-spacing: -0.005em;
			}
			.row-tag {
				justify-self: end;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				padding: 0.25em 0.7em;
				border: 1px solid var(--rule);
				color: var(--ink-soft);
				border-radius: 2px;
				white-space: nowrap;
			}
			.row-tag--rust {
				color: var(--rust);
				border-color: rgba(184, 69, 31, 0.45);
			}
			.row-tag--teal {
				color: var(--teal);
				border-color: rgba(45, 88, 98, 0.45);
			}

			.note {
				margin-top: 4em;
				padding: 2em 2.5em;
				background: var(--paper-deep);
				border-left: 2px solid var(--rust);
			}
			.note .label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--mute);
				display: block;
				margin-bottom: 0.5em;
			}
			.note p {
				margin: 0;
				font-family: var(--font-display);
				font-weight: 300;
				font-size: 1.15rem;
				color: var(--ink);
				line-height: 1.45;
				letter-spacing: -0.01em;
			}

			@media (max-width: 820px) {
				.page-head,
				.day {
					grid-template-columns: 1fr;
					gap: 1.5em;
				}
				.day-rail {
					position: static;
				}
				.day-num {
					font-size: 5.5rem;
				}
				.row {
					grid-template-columns: 4rem 1fr;
				}
				.row-tag {
					grid-column: 1 / -1;
					justify-self: start;
				}
				.venue-card {
					border-left: none;
					padding: 1.5em 0 0;
					border-top: 1px solid var(--rule);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<div>
					<div class="head-eyebrow">
						<Mark size={12} color="var(--rust)" variant="node" />
						<span class="eyebrow">Three Days · Argonne National Lab</span>
					</div>
					<h1>
						Schedule<em>.</em>
					</h1>
				</div>
				<div class="venue-card">
					<div>
						<span class="venue-label">Venue</span>
						<div class="venue-room">Room 1416, Building 240</div>
						<div class="venue-addr">
							Argonne National Laboratory<br />
							9700 S Cass Ave, Lemont, IL
						</div>
					</div>
				</div>
			</section>

			{
				days.map((day) => (
					<section class="day">
						<div class="day-rail">
							<div class="day-num">{day.num}</div>
							<div class="day-weekday">
								{day.weekday} · Day {String(days.indexOf(day) + 1)}
							</div>
							<div class="day-date">{day.date}</div>
							<div class="day-theme">{day.theme}</div>
						</div>

						<div class="day-body">
							{day.items.map((item) => (
								<div class:list={["row", { "row--muted": item.muted }]}>
									<div class="row-time">{item.time}</div>
									<div class="row-title">{item.title}</div>
									{item.tag ? (
										<span
											class:list={[
												"row-tag",
												{
													"row-tag--rust":
														item.tag === "Keynote" ||
														item.tag === "Finale" ||
														item.tag === "Reports",
													"row-tag--teal":
														item.tag === "Tour" || item.tag === "Build",
												},
											]}
										>
											{item.tag}
										</span>
									) : (
										<span />
									)}
								</div>
							))}
						</div>
					</section>
				))
			}

			<aside class="note">
				<span class="label">A note on the agenda</span>
				<p>
					Times are tentative and may shift as teams converge on their
					prototypes. Bring a laptop and an appetite for fast iteration.
				</p>
			</aside>
		</main>
		<Footer />
	</body>
</html>
